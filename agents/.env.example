# .env.example — copy this to .env and fill in your values
# NEVER commit .env to git (it's already in .gitignore)

# ── Groq API (get from console.groq.com) ──────────────────────────
GROQ_API_KEY=your_new_groq_key_here

# ── TenderIQ API keys (clients must send one of these in X-API-Key header)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TENDERIQ_API_KEYS=your_generated_key_here,optional_second_key

# ── CORS — comma-separated list of allowed frontend origins ────────
ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
# For local dev: http://localhost:5173,http://localhost:3000
