# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
JWT_SECRET=supersecretkey
JWT_ALGORITHM=HS256
JWT_AUDIENCE=agentic-ai-tender
JWT_ISSUER=agentic-ai-tender

# Auth Service
AUTH_SERVICE_PORT=8001
AUTH_SERVICE_URL=http://localhost:8001

# Tender Service
TENDER_SERVICE_PORT=8002
TENDER_SERVICE_URL=http://localhost:8002

# Analysis Service
ANALYSIS_SERVICE_PORT=8003
ANALYSIS_SERVICE_URL=http://localhost:8003

# Notification Service
NOTIFICATION_SERVICE_PORT=8004
NOTIFICATION_SERVICE_URL=http://localhost:8004

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentic_ai_tender
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/agentic_ai_tender
ALLOW_PUBLIC_TENDERS=true

# API
NEXT_PUBLIC_API_URL=http://localhost:8000
GATEWAY_EVENT_URL=http://localhost:8000/events
DEFAULT_SCRAPER_URL=https://cppt.gov.in/tenders

# AI
OPENROUTER_API_URL=https://api.openrouter.ai/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_MODEL=gpt-4o-mini

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=agentic-ai-tender
